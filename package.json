{
  "name": "bp100",
  "version": "0.1.0",
  "private": true,
  "license": "LGPL-3.0",
  "packageManager": "pnpm@10.6.2",
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@tsconfig/node18": "^18.2.6",
    "@types/node": "^24.13.2",
    "@types/semver": "^7.7.1",
    "concurrently": "^9.2.3",
    "copyfiles": "^2.4.1",
    "del-cli": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "factorio-test": "^3.0.0",
    "factorio-test-cli": "^3.6.0",
    "factoriomod-debug": "^2.1.2",
    "gb-tstl-utils": "^1.0.2",
    "globals": "^17.7.0",
    "lua-types": "^2.14.1",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "semver": "^7.8.5",
    "tstl-expect": "^0.4.6",
    "tsx": "^4.22.4",
    "typed-factorio": "^4.0.1",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.62.0",
    "typescript-to-lua": "^1.37.0",
    "typescript-tstl-plugin": "^0.3.2"
  },
  "type": "module",
  "scripts": {
    "clean": "del-cli \"src/**/*.lua\" \"src/**/*.map\" \"!**/*.def.lua\"",
    "build:locale": "tsx scripts/gen-locale-defs.ts",
    "build:gui-specs": "tsx scripts/gen-gui-specs.ts",
    "build:tstlPlugin": "tsc -p tstlPlugin/tsconfig.json",
    "build:scripts": "conc \"pnpm:build:locale\" \"pnpm:build:gui-specs\" \"pnpm:build:tstlPlugin\"",
    "build:release": "pnpm run clean && pnpm run build:scripts && echo Starting production build... && tstl -p tsconfig-release.json && echo Done",
    "build:test": "pnpm run build:scripts && echo Starting test build... && tstl && echo Done",
    "prepackage": "copyfiles COPYING* src && pnpm run check-clean-tree",
    "postpackage": "del-cli src/COPYING*",
    "watch": "tstl --watch",
    "watch:locale": "nodemon scripts/gen-locale-defs.ts",
    "watch:release": "tstl --watch -p tsconfig-release.json",
    "format:fix": "prettier --write \"src/**/*.ts\" \"src/**/*.tsx\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"src/**/*.tsx\"",
    "lint": "eslint",
    "pretest": "tstl",
    "test": "factorio-test run",
    "test:rebuild": "pnpm run clean && pnpm run build:test && pnpm run test",
    "check-clean-tree": "git diff --exit-code HEAD --",
    "check": "conc \"pnpm:format:check\" \"pnpm:lint\" \"pnpm:test\" \"pnpm:check-clean-tree\"",
    "subst-current-version": "tsx scripts/subst-current-version.ts",
    "version-minor": "tsx scripts/bump-version.ts minor",
    "publish-mod": "export $(xargs <.env) && cd src && fmtk publish"
  },
  "nodemonConfig": {
    "watch": [
      "src/locale/en/*.cfg"
    ],
    "ext": "*",
    "execMap": {
      "ts": "tsx"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ]
  }
}
